---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Our Story | Nirmal & Sumi">

  <section class="text-center py-20 px-6">
    <h1 class="section-title">Our Story</h1>
    <div class="section-divider max-w-xs mx-auto mt-6">
      <span class="divider-motif">❋</span>
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-6 pb-16 text-center">
    <div class="font-serif text-2xl md:text-3xl font-light leading-relaxed text-maroon space-y-3 italic">
      <p>A story of two people,</p>
      <p>Separated by everything geography could throw at them,</p>
      <p>Making quiet sacrifices, waiting for the world to catch up.</p>
      <p>But we stayed,</p>
      <p>And this is where the goodbyes end.</p>
    </div>
  </section>

  <div class="section-divider max-w-3xl mx-auto px-6">
    <span class="divider-motif">◆</span>
  </div>

  <!-- Three icons representing who they are -->
  <section class="max-w-2xl mx-auto px-6 py-14 grid grid-cols-3 gap-8 text-center">

    <!-- Dance -->
    <div class="flex flex-col items-center gap-3">
      <svg viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg" class="w-20 h-24">
        <!-- Him -->
        <circle cx="35" cy="14" r="8" fill="#8B3A2A"/>
        <path d="M35 22 Q28 38 30 55 Q32 65 26 78" stroke="#8B3A2A" stroke-width="3.5" fill="none" stroke-linecap="round"/>
        <path d="M30 55 Q20 62 16 72" stroke="#8B3A2A" stroke-width="3" fill="none" stroke-linecap="round"/>
        <path d="M30 55 Q38 60 44 70" stroke="#8B3A2A" stroke-width="3" fill="none" stroke-linecap="round"/>
        <path d="M26 78 Q22 88 20 98" stroke="#8B3A2A" stroke-width="3" fill="none" stroke-linecap="round"/>
        <path d="M26 78 Q30 88 34 96" stroke="#8B3A2A" stroke-width="3" fill="none" stroke-linecap="round"/>
        <!-- Her — raised arm pose -->
        <circle cx="65" cy="10" r="8" fill="#C9A84C"/>
        <path d="M65 18 Q72 32 68 50 Q66 62 70 76" stroke="#C9A84C" stroke-width="3.5" fill="none" stroke-linecap="round"/>
        <path d="M68 50 Q60 56 56 66" stroke="#C9A84C" stroke-width="3" fill="none" stroke-linecap="round"/>
        <path d="M68 50 Q78 40 86 28" stroke="#C9A84C" stroke-width="3" fill="none" stroke-linecap="round"/>
        <path d="M70 76 Q66 88 62 100" stroke="#C9A84C" stroke-width="3" fill="none" stroke-linecap="round"/>
        <path d="M70 76 Q74 86 76 98" stroke="#C9A84C" stroke-width="3" fill="none" stroke-linecap="round"/>
        <!-- Joined hands -->
        <path d="M44 70 Q54 74 56 66" stroke="#3D2314" stroke-width="2.5" fill="none" stroke-linecap="round"/>
      </svg>
      <p class="font-sans text-xs tracking-widest uppercase text-brown-light">Dance</p>
    </div>

    <!-- Books -->
    <div class="flex flex-col items-center gap-3">
      <svg viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg" class="w-20 h-24">
        <!-- Bottom book -->
        <rect x="10" y="88" width="80" height="16" rx="2" fill="#8B3A2A"/>
        <rect x="10" y="88" width="8" height="16" rx="1" fill="#5C2418"/>
        <line x1="22" y1="93" x2="82" y2="93" stroke="#C9A84C" stroke-width="1" opacity="0.6"/>
        <line x1="22" y1="98" x2="70" y2="98" stroke="#C9A84C" stroke-width="1" opacity="0.4"/>
        <!-- Middle book -->
        <rect x="14" y="66" width="72" height="16" rx="2" fill="#C9A84C"/>
        <rect x="14" y="66" width="8" height="16" rx="1" fill="#A88030"/>
        <line x1="26" y1="71" x2="78" y2="71" stroke="#8B3A2A" stroke-width="1" opacity="0.5"/>
        <line x1="26" y1="76" x2="66" y2="76" stroke="#8B3A2A" stroke-width="1" opacity="0.4"/>
        <!-- Top book — open -->
        <path d="M18 42 Q50 36 82 42 L82 64 Q50 58 18 64 Z" fill="#F5EDD8" stroke="#8B3A2A" stroke-width="1.5"/>
        <path d="M50 38 L50 64" stroke="#8B3A2A" stroke-width="1.5"/>
        <line x1="24" y1="48" x2="48" y2="46" stroke="#9C8B7A" stroke-width="1" opacity="0.6"/>
        <line x1="24" y1="53" x2="48" y2="51" stroke="#9C8B7A" stroke-width="1" opacity="0.4"/>
        <line x1="24" y1="58" x2="48" y2="56" stroke="#9C8B7A" stroke-width="1" opacity="0.3"/>
        <line x1="52" y1="46" x2="76" y2="48" stroke="#9C8B7A" stroke-width="1" opacity="0.6"/>
        <line x1="52" y1="51" x2="76" y2="53" stroke="#9C8B7A" stroke-width="1" opacity="0.4"/>
        <line x1="52" y1="56" x2="76" y2="58" stroke="#9C8B7A" stroke-width="1" opacity="0.3"/>
        <!-- Bookmark -->
        <path d="M72 36 L72 18 L78 22 L84 18 L84 36 Z" fill="#8B3A2A"/>
      </svg>
      <p class="font-sans text-xs tracking-widest uppercase text-brown-light">Books</p>
    </div>

    <!-- Computer Graphics -->
    <div class="flex flex-col items-center gap-3">
      <svg viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg" class="w-20 h-24">
        <!-- Monitor -->
        <rect x="8" y="20" width="84" height="62" rx="4" fill="#3D2314"/>
        <rect x="13" y="25" width="74" height="52" rx="2" fill="#F5EDD8"/>
        <!-- Screen content — bezier curves suggesting CG work -->
        <path d="M20 60 Q35 35 50 50 Q65 65 80 40" stroke="#8B3A2A" stroke-width="2" fill="none" stroke-linecap="round"/>
        <path d="M20 65 Q35 45 50 55 Q65 65 80 48" stroke="#C9A84C" stroke-width="1.5" fill="none" stroke-linecap="round" opacity="0.7"/>
        <!-- Control points -->
        <circle cx="35" cy="38" r="3" fill="#8B3A2A"/>
        <circle cx="65" cy="62" r="3" fill="#8B3A2A"/>
        <line x1="20" y1="60" x2="35" y2="38" stroke="#8B3A2A" stroke-width="1" stroke-dasharray="3,2" opacity="0.5"/>
        <line x1="50" y1="50" x2="35" y2="38" stroke="#8B3A2A" stroke-width="1" stroke-dasharray="3,2" opacity="0.5"/>
        <line x1="50" y1="50" x2="65" y2="62" stroke="#8B3A2A" stroke-width="1" stroke-dasharray="3,2" opacity="0.5"/>
        <line x1="80" y1="40" x2="65" y2="62" stroke="#8B3A2A" stroke-width="1" stroke-dasharray="3,2" opacity="0.5"/>
        <!-- Stand -->
        <rect x="42" y="82" width="16" height="8" fill="#3D2314"/>
        <rect x="30" y="90" width="40" height="6" rx="2" fill="#3D2314"/>
      </svg>
      <p class="font-sans text-xs tracking-widest uppercase text-brown-light">Computer Graphics</p>
    </div>

  </section>

  <div class="section-divider max-w-3xl mx-auto px-6">
    <span class="divider-motif">◆</span>
  </div>

  <!-- Horizontal Timeline -->
  <section class="px-6 py-16 overflow-x-auto">
    <div class="min-w-[560px] max-w-3xl mx-auto">
      <!-- Connector line + dots row -->
      <div class="relative flex items-center">
        <!-- Full-width horizontal line -->
        <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 h-px bg-gold opacity-30"></div>

        <!-- Node: Introduced July 2019 -->
        <div class="relative flex flex-col items-center flex-1">
          <div class="w-3 h-3 rounded-full bg-cream border-2 border-gold z-10"></div>
        </div>
        <!-- Node: ...stuff! -->
        <div class="relative flex flex-col items-center flex-1">
          <div class="w-3 h-3 rounded-full bg-cream border-2 border-gold z-10"></div>
        </div>
        <!-- Node: and here we are! -->
        <div class="relative flex flex-col items-center flex-1">
          <div class="w-3 h-3 rounded-full bg-maroon border-2 border-maroon z-10"></div>
        </div>
      </div>

      <!-- Labels row -->
      <div class="flex mt-5 text-center">
        <div class="flex-1 px-2">
          <p class="font-serif text-sm text-maroon leading-snug">Introduced</p>
          <p class="font-sans text-xs text-brown-light mt-0.5">July 2019</p>
        </div>
        <div class="flex-1 px-2">
          <p class="font-serif text-sm text-brown leading-snug italic">...stuff!</p>
        </div>
        <div class="flex-1 px-2">
          <p class="font-serif text-sm text-maroon leading-snug italic">and here we are!</p>
          <p class="font-sans text-xs text-brown-light mt-0.5">September 2026</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 px-6 flex justify-center">
    <div class="w-full max-w-sm md:max-w-md">
      <img
        src="/invite.png"
        alt="Nirmal & Sumi Wedding Invitation"
        class="w-full shadow-xl rounded-sm border border-gold border-opacity-20"
      />
    </div>
  </section>

  <section class="text-center py-16 px-6">
    <p class="font-sans text-xs tracking-widest uppercase text-brown-light mb-6">We'd love to see you there</p>
    <a href="/rsvp" class="btn-primary">RSVP Now</a>
  </section>

</Layout>
