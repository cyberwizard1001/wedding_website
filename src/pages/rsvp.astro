---
import Layout from '../layouts/Layout.astro';
---

<Layout title="RSVP | Nirmal & Sumi">

  <section class="text-center pt-12 pb-8 px-6">
    <p class="font-sans text-xs tracking-[0.4em] uppercase text-gold mb-3">Kindly respond by</p>
    <h1 class="section-title">RSVP</h1>
    <p class="font-serif italic text-brown-light text-lg font-light mt-3 mb-6">
      Please let us know if you'll be joining us by <strong class="not-italic text-maroon">20th August 2026</strong>.
    </p>
    <div class="max-w-3xl mx-auto grid sm:grid-cols-2 gap-4">
      <div class="flex items-center justify-center gap-4 bg-cream-dark px-6 py-4 border border-gold border-opacity-20">
        <div class="text-center">
          <p class="font-sans text-xs tracking-widest uppercase text-gold mb-0.5">Day 1 · Reception</p>
          <p class="font-serif text-lg text-maroon">Sunday, 6th September</p>
          <p class="font-sans text-xs text-brown-light mt-0.5">6:30 – 9:30 pm · Subhasree Hall</p>
        </div>
      </div>
      <div class="flex items-center justify-center gap-4 bg-cream-dark px-6 py-4 border border-gold border-opacity-20">
        <div class="text-center">
          <p class="font-sans text-xs tracking-widest uppercase text-gold mb-0.5">Day 2 · Ceremony</p>
          <p class="font-serif text-lg text-maroon">Monday, 7th September</p>
          <p class="font-sans text-xs text-brown-light mt-0.5">9:00 – 10:30 am · Subhasree Hall</p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-16 pt-6">
    <iframe
      data-tally-src="https://tally.so/embed/b5zNd2?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
      loading="lazy"
      width="100%"
      height="469"
      frameborder="0"
      marginheight="0"
      marginwidth="0"
      title="Nirmal & Sumi wedding - RSVP"
    ></iframe>
    <script>
      var d = document,
        w = "https://tally.so/widgets/embed.js",
        v = function () {
          "undefined" != typeof Tally
            ? Tally.loadEmbeds()
            : d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach(function (e) {
                e.src = e.dataset.tallySrc;
              });
        };
      if ("undefined" != typeof Tally) v();
      else if (d.querySelector('script[src="' + w + '"]') == null) {
        var s = d.createElement("script");
        s.src = w;
        s.onload = v;
        s.onerror = v;
        d.body.appendChild(s);
      }
    </script>
  </section>

  <section class="max-w-2xl mx-auto px-6 py-16 text-center">
    <p class="font-sans text-sm text-brown-light leading-relaxed">
      Questions about the event? Reach us at{' '}
      <a href="mailto:nirmalkarthikeyan1503@gmail.com" class="text-maroon underline">
        nirmalkarthikeyan1503@gmail.com
      </a>
    </p>
  </section>

</Layout>
