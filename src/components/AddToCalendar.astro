---
import { withBase } from '../utils/base';

const receptionGoogle = 'https://calendar.google.com/calendar/render?action=TEMPLATE'
  + '&text=Nirmal+%26+Sumi+%E2%80%94+Reception'
  + '&dates=20260906T130000Z/20260906T160000Z'
  + '&details=Reception+celebrating+the+wedding+of+Nirmal+%26+Sumi'
  + '&location=Subhasree+Hall%2C+Ramnagar%2C+Coimbatore+641+009';

const ceremonyGoogle = 'https://calendar.google.com/calendar/render?action=TEMPLATE'
  + '&text=Nirmal+%26+Sumi+%E2%80%94+Wedding+Ceremony'
  + '&dates=20260907T033000Z/20260907T050000Z'
  + '&details=Wedding+ceremony+for+Nirmal+%26+Sumi.+Please+arrive+by+8%3A30am.'
  + '&location=Subhasree+Hall%2C+Ramnagar%2C+Coimbatore+641+009';
---

<div class="relative inline-block" id="cal-dropdown">
  <button
    id="cal-btn"
    class="btn-outline flex items-center gap-2 text-xs"
    aria-haspopup="true"
    aria-expanded="false"
  >
    <span>Add to Calendar</span>
    <span class="text-gold text-xs" id="cal-chevron">▾</span>
  </button>

  <div
    id="cal-menu"
    class="hidden fixed bg-cream-light border border-gold border-opacity-40 shadow-lg z-50 w-72"
    role="menu"
  >
    <a
      href={withBase('/wedding.ics')}
      download="Nirmal-Sumi-Wedding.ics"
      class="flex items-start gap-3 px-4 py-3 hover:bg-cream transition-colors group border-b border-gold border-opacity-20"
      role="menuitem"
    >
      <div class="flex-1">
        <p class="font-sans text-xs text-brown group-hover:text-maroon transition-colors font-medium">Add both events at once</p>
        <p class="font-sans text-xs text-brown-light mt-0.5 leading-relaxed">
          Downloads a .ics file that works with Apple Calendar, Google Calendar, and Outlook.
        </p>
      </div>
    </a>

    <p class="px-4 pt-3 pb-1 font-sans text-xs tracking-widest uppercase text-gold">Or add individually</p>

    <div class="px-4 py-2.5 border-b border-gold border-opacity-10 text-center">
      <p class="font-sans text-xs text-brown mb-1.5">Reception <span class="text-brown-light font-normal">· Sun 6 Sep, 6:30–9:30 pm</span></p>
      <div class="flex justify-center gap-3">
        <a href={receptionGoogle} target="_blank" rel="noopener noreferrer"
          class="font-sans text-xs text-maroon underline hover:text-maroon-dark transition-colors">
          Google Calendar
        </a>
        <span class="text-gold opacity-40">·</span>
        <a href={withBase('/reception.ics')} download="Nirmal-Sumi-Reception.ics"
          class="font-sans text-xs text-maroon underline hover:text-maroon-dark transition-colors">
          Apple / Outlook
        </a>
      </div>
    </div>

    <div class="px-4 py-2.5 mb-1 text-center">
      <p class="font-sans text-xs text-brown mb-1.5">Wedding Ceremony <span class="text-brown-light font-normal">· Mon 7 Sep, 9:00–10:30 am</span></p>
      <div class="flex justify-center gap-3">
        <a href={ceremonyGoogle} target="_blank" rel="noopener noreferrer"
          class="font-sans text-xs text-maroon underline hover:text-maroon-dark transition-colors">
          Google Calendar
        </a>
        <span class="text-gold opacity-40">·</span>
        <a href={withBase('/ceremony.ics')} download="Nirmal-Sumi-Ceremony.ics"
          class="font-sans text-xs text-maroon underline hover:text-maroon-dark transition-colors">
          Apple / Outlook
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('cal-btn');
  const menu = document.getElementById('cal-menu');
  const chevron = document.getElementById('cal-chevron');

  function positionMenu() {
    if (!btn || !menu) return;
    const rect = btn.getBoundingClientRect();
    const menuWidth = 288;
    const margin = 8;
    let left = rect.left + rect.width / 2 - menuWidth / 2;
    left = Math.max(margin, Math.min(left, window.innerWidth - menuWidth - margin));
    menu.style.top = `${rect.bottom + 4}px`;
    menu.style.left = `${left}px`;
  }

  btn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !menu?.classList.contains('hidden');
    if (!isOpen) positionMenu();
    menu?.classList.toggle('hidden', isOpen);
    if (chevron) chevron.textContent = isOpen ? '▾' : '▴';
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  document.addEventListener('click', () => {
    menu?.classList.add('hidden');
    if (chevron) chevron.textContent = '▾';
    btn?.setAttribute('aria-expanded', 'false');
  });

  menu?.addEventListener('click', (e) => e.stopPropagation());
</script>
