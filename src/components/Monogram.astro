---
interface Props {
  class?: string;
  tone?: 'default' | 'light';
}

const { class: className = '', tone = 'default' } = Astro.props;

const letterColor = tone === 'light' ? '#FDF8EE' : '#962B1D';
const ringColor = tone === 'light' ? '#E0A93A' : '#962B1D';
const ampColor = '#E0A93A';
---

<svg viewBox="0 0 64 64" class={`monogram ${className}`} aria-hidden="true">
  <circle cx="32" cy="32" r="29" fill="none" stroke={ringColor} stroke-width="1" opacity="0.55" />
  <text x="20" y="40" font-family="'Cormorant Garamond', Georgia, serif" font-size="25" font-weight="500" fill={letterColor} text-anchor="middle">N</text>
  <text x="32" y="32" font-family="'Cormorant Garamond', Georgia, serif" font-size="13" font-style="italic" font-weight="400" fill={ampColor} text-anchor="middle">&amp;</text>
  <text x="44" y="40" font-family="'Cormorant Garamond', Georgia, serif" font-size="25" font-weight="500" fill={letterColor} text-anchor="middle">S</text>
</svg>
